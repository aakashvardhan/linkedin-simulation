# Copy to `.env` for docker-compose in this folder, or set the same variables in the shell / root `.env`
# when using the root `docker-compose.yml` (see OPENROUTER_API_KEY / GROQ_API_KEY there).

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

KAFKA_BOOTSTRAP=ai_kafka:9092
MONGO_URI=mongodb://ai_mongo:27017
REDIS_URL=redis://ai_redis:6379
