APP_NAME=LinkedIn Simulation  for M3/M4 Backend
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
AUTO_CREATE_SCHEMA=true

# Production/staging: set to https origins of your SPA(s), comma-separated (required for browser clients).
# Example: CORS_ORIGINS=https://app.example.com,https://staging.example.com
# Leave empty for local dev (defaults to localhost Vite/React ports).
CORS_ORIGINS=

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=linkedin_simulation
MYSQL_USER=root
# Must match a MySQL user that can access MYSQL_DB (often `root` on localhost).
MYSQL_PASSWORD=

# Default local install (Homebrew: mongodb-community@7.0 on 27017).
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=linkedin_simulation

ENABLE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=linkedin-m3m4-backend
KAFKA_CONSUMER_GROUP=linkedin-events-consumer

JWT_SECRET=change-me-in-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional cache (ElastiCache). If unreachable, API continues without cache.
REDIS_URL=redis://127.0.0.1:6379/0
