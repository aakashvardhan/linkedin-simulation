# .env for seed scripts — copy to seed/.env and fill in values
# These match your docker-compose.yml environment variables

# MySQL (matches docker-compose.yml x-mysql-env)
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=linkedin_pass
DB_NAME=linkedin_simulation

# MongoDB (matches docker-compose.yml x-mongo-env)
MONGO_URI=mongodb://localhost:27017/linkedin_simulation

# Verification script targets
ANALYTICS_URL=http://localhost:8006
JOB_ID=1
MEMBER_ID=1
RECRUITER_ID=1
