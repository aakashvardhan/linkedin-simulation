# Copy this file to `.env` and fill in real values for local development.
# Do NOT commit `.env`.

# --- LLM provider (Groq) -----------------------------------------------------
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# --- Infrastructure ---------------------------------------------------------
# When running uvicorn on your machine (Redis/Mongo/Kafka exposed on localhost):
KAFKA_BOOTSTRAP=localhost:9093
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ai_service
REDIS_URL=redis://localhost:6379
#
# When the ai-service app runs *inside* docker-compose, docker-compose.yml sets
# KAFKA_BOOTSTRAP, MONGO_URI, and REDIS_URL for in-network hostnames — do not rely
# on `redis://ai_redis` or other container_name values from the host; use
# localhost URLs only for host-side processes.

# --- Downstream services ----------------------------------------------------
# uvicorn on the host + mocks on the host: use 127.0.0.1 (not "localhost") —
# stubs bind IPv4 only; "localhost" may resolve to ::1 and httpx will fail.
#
# If ai-service runs via docker-compose.yml, that file sets JOB_SERVICE_URL /
# PROFILE_SERVICE_URL to http://host.docker.internal:8002|8001 so the container
# can reach stubs on your machine. You normally do not need to duplicate that here.
PROFILE_SERVICE_URL=http://127.0.0.1:8001
JOB_SERVICE_URL=http://127.0.0.1:8002
MESSAGING_SERVICE_URL=http://localhost:8005

# --- HTTP client tuning ------------------------------------------------------
HTTP_CLIENT_TIMEOUT=5.0
