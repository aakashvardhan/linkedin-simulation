# Copy this file to `.env` and fill in real values for local development.
# Do NOT commit `.env`.

# --- LLM provider (Groq) -----------------------------------------------------
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# --- Infrastructure ---------------------------------------------------------
# Matches ai-service/docker-compose.yml PLAINTEXT_HOST (host port 9093).
KAFKA_BOOTSTRAP=localhost:9093
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ai_service
REDIS_URL=redis://localhost:6379

# --- Downstream services ----------------------------------------------------
PROFILE_SERVICE_URL=http://localhost:8001
JOB_SERVICE_URL=http://localhost:8002
MESSAGING_SERVICE_URL=http://localhost:8005

# --- HTTP client tuning ------------------------------------------------------
HTTP_CLIENT_TIMEOUT=5.0
