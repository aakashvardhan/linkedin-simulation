# Core backend (FastAPI) — local default port 8000.
# AWS / staging: set to your public API origin (ALB, API Gateway, or custom domain), no trailing slash.
# Example: VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend integration toggles (recommended for integration testing with real services)
#
# When true, loads jobs from the backend after login (`/jobs/search` or `/jobs/byRecruiter`).
VITE_BACKEND_INTEGRATION=true

# Prefer backend job rows over bundled seeds: defaults to on when VITE_BACKEND_INTEGRATION=true and VITE_DEMO_SEED=false.
# Override with VITE_REPLACE_SEED_JOBS=false if you still want to merge seeds while integrating.
# VITE_REPLACE_SEED_JOBS=true
#
# Member network: defaults to replacing local/seed connections with /connections/list + /connections/pending when integrating without demo seed.
# VITE_REPLACE_SEED_CONNECTIONS=true
#
# When true (default), sign-in must hit the real login APIs and `/auth/me` — no fake Google or silent offline session.
# Set to false only for local UI demos without a backend.
# VITE_REQUIRE_BACKEND_AUTH=false
#
# When false (recommended with a real backend): no bundled JSON seeds, no DummyJSON merge, no synthetic applicants/analytics fallbacks.
VITE_DEMO_SEED=false

# When true, Career Coach can use the local rule-based planner if /ai/* is unavailable.
# VITE_CAREER_COACH_OFFLINE=false
#
# When true, Easy Apply waits for POST /applications/submit before updating UI; failures show an error instead of silent demo success.
# VITE_STRICT_APPLICATIONS=false

# Open dummy data: merges DummyJSON (users + quotes) into feed/jobs/network on load. Set to false to skip.
# VITE_OPEN_SEED=false

# Optional: URL to your own JSON (e.g. static file after exporting Kaggle CSV). Shape:
# { "jobs": [...], "posts": [...], "connections": [...] } — each array optional.
# VITE_EXTRA_SEED_URL=https://example.com/my-seed.json
