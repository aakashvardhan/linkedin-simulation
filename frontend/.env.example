VITE_API_BASE_URL=http://localhost:8080

# Backend integration toggles (recommended for integration testing with real services)
#
# When true, enables optional hydration calls after login (jobs/search today; safe no-ops if endpoints differ).
# VITE_BACKEND_INTEGRATION=true
#
# When true, disables local demo fallbacks that hide backend failures (signup/signin must succeed against /auth/login).
# VITE_REQUIRE_BACKEND_AUTH=false
#
# When false, disables DummyJSON + optional extra seed merge entirely (cleaner against real datasets).
# VITE_DEMO_SEED=true
#
# When true, replaces the in-memory jobs list with backend results during hydration (still falls back to seeds if empty).
# VITE_REPLACE_SEED_JOBS=false

# Open dummy data: merges DummyJSON (users + quotes) into feed/jobs/network on load. Set to false to skip.
# VITE_OPEN_SEED=false

# Optional: URL to your own JSON (e.g. static file after exporting Kaggle CSV). Shape:
# { "jobs": [...], "posts": [...], "connections": [...] } — each array optional.
# VITE_EXTRA_SEED_URL=https://example.com/my-seed.json
